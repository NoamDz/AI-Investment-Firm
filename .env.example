# Broker selection: FAKE (default, zero-setup) or ALPACA
FIRM_BROKER=FAKE

# Alpaca paper trading credentials (only required if FIRM_BROKER=ALPACA)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# HMAC secret for signing decision nonces and HITL approvals
FIRM_HMAC_SECRET=change-me-to-a-32-byte-hex-string

# Database path
FIRM_DB_PATH=data/firm.db

# Anthropic API key (required for LLM-backed agents in Plan 2)
ANTHROPIC_API_KEY=

# Qdrant vector database URL (docker-compose service)
QDRANT_URL=http://localhost:6333

# LLM mode: live (real API calls), cached (read from DB cache), record (call + store)
FIRM_LLM_MODE=cached

# Plan 2 config paths
FIRM_RAG_CONFIG=config/rag.yaml
FIRM_LLM_CONFIG=config/llm.yaml
