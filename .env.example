# Copy to `.env` and fill in your API key. docker-compose auto-loads `.env`.
ANTHROPIC_API_KEY=sk-ant-...

# LLM cache mode (used by the firm container):
#   live   — real API call, response written to cache (default)
#   record — same as live, plus a log line saying "new entry written"
#   cached — read-only; raises on cache miss. Use after first run for instant replays.
FIRM_LLM_MODE=live

# --- Native ingest (step 3 in README) ---
# Set in your shell before `python -m firm.cli ingest`:
#   $env:FIRM_INGEST_MAX_DOCS = "20"    # 20 docs ≈ 3 min on GPU; unset for full corpus (~30 min)
#   $env:QDRANT_URL = "http://localhost:6333"

# --- Required when running `firm run` natively (Docker users skip this) ---
# 32-byte hex string used as HMAC nonce secret for signed decisions.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# In docker-compose.yml the firm service already sets this; only set here if you
# bypass Docker and invoke `python -m firm.cli run ...` from the host.
# FIRM_HMAC_SECRET=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# --- Optional: real paper trading via Alpaca ---
# FIRM_BROKER=ALPACA
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
